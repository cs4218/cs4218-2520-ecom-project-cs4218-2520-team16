{
  "name": "ecom",
  "version": "1.0.0",
  "description": "ecommerce rest api",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "npm start --prefix ./client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "sonarqube": "sonar-scanner",
    "test:coverage": "jest --config jest.config.js --coverage --coverageReporters=lcov --coverageReporters=text-summary",
    "sonar:scan": "sonar-scanner -Dsonar.token=$SONAR_TOKEN",
    "sonar:report": "npm run test:coverage && npm run sonar:scan",
    "test:load": "artillery run --target ${LOAD_TEST_BASE_URL:-http://localhost:6060} load-tests/public-catalog-load-test.yml",
    "test:load:smoke": "artillery run --target ${LOAD_TEST_BASE_URL:-http://localhost:6060} load-tests/public-catalog-smoke-load-test.yml",
    "test:load:stress": "artillery run --target ${LOAD_TEST_BASE_URL:-http://localhost:6060} load-tests/public-catalog-stress-load-test.yml",
    "test:load:soak": "artillery run --target ${LOAD_TEST_BASE_URL:-http://localhost:6060} load-tests/public-catalog-soak-load-test.yml",
    "test:load:report": "artillery run --target ${LOAD_TEST_BASE_URL:-http://localhost:6060} --output test-results/load-test-report.json load-tests/public-catalog-load-test.yml",
    "test": "npm run test:backend && npm run test:frontend && npm run test:ui",
    "test:frontend": "jest --config jest.frontend.config.js --watchAll=false",
    "test:backend": "jest --config jest.backend.config.js",
    "test:ui": "playwright test",
    "test:ui:ci": "playwright test --reporter=line --max-failures=10",
    "test:ui:headed": "playwright test --headed",
    "test:ui:debug": "playwright test --debug",
    "test:ui:report": "playwright show-report"
  },
  "keywords": [],
  "author": "RP",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "braintree": "^3.22.0",
    "colors": "^1.4.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-formidable": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.3.0",
    "mongoose": "^8.1.2",
    "morgan": "^1.10.0",
    "nodemon": "^3.0.3",
    "react-icons": "^5.0.1",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-react": "^7.24.1",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.12",
    "babel-jest": "^29.7.0",
    "artillery": "^2.0.30",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "sonarqube-scanner": "^3.3.0"
  },
  "type": "module"
}
